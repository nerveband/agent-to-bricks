# Canonical staging configuration
ATB_STAGING_URL="https://ts-staging.example.com"
ATB_STAGING_API_KEY="atb_replace_me"
# These can point to one shared fixture page or three dedicated fixture pages.
ATB_STAGING_READ_PAGE_ID=1338
ATB_STAGING_SCRATCH_PAGE_ID=1338
ATB_STAGING_TEMPLATE_PAGE_ID=1338

# Deploy / WP-CLI access for staging automation
SSH_HOST="runcloud@example.com"
WP_PATH="/home/runcloud/webapps/example-app"
PHP_BIN="/RunCloud/Packages/php83rc/bin/php"
WPCLI_BIN="/usr/local/bin/wp"
WP_APP_USER="runcloud"

# Optional backward-compatible aliases still supported by helper scripts
# WP_STAGING_URL="https://ts-staging.example.com"
# ATB_API_KEY="atb_replace_me"
# TEST_PAGE_ID=1338

# Optional private/local-only fixture pack:
# docs/test-data/ may contain proprietary Bricks templates and is intentionally gitignored.
# Public clones should run without it; the corpus tests skip automatically when it is absent.
